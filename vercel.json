{
  "functions": {
    "api/xquik.js": { "maxDuration": 60 },
    "api/news.js": { "maxDuration": 30 },
    "api/serpapi.js": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://xquik.com https://generativelanguage.googleapis.com https://*.supabase.co; frame-src 'none'; object-src 'none'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/serpapi", "destination": "/api/serpapi" },
    { "source": "/api/news", "destination": "/api/news" },
    { "source": "/api/xquik", "destination": "/api/xquik" },
    { "source": "/api/image-proxy", "destination": "/api/image-proxy" },
    { "source": "/api/style-webhook", "destination": "/api/style-webhook" },
    { "source": "/api/generate-tweet", "destination": "/api/generate-tweet" },
    { "source": "/api/extract-topics", "destination": "/api/extract-topics" },
    { "source": "/api/generate-prompt", "destination": "/api/generate-prompt" },
    { "source": "/api/search-viral", "destination": "/api/search-viral" },
    { "source": "/api/analyze-personality", "destination": "/api/analyze-personality" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
